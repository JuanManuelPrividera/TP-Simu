%% Calibración del modelo: normal truncada con promedio 5 min y desvío 0,333 min
%% en [3,333; 6,667] min. Conserva el coeficiente de variación de la calibración
%% anterior y concentra la masa alrededor de 5 minutos.
flowchart TD
    inicio{{TConf}} --> r1{{R1 ~ U(0,1)}} --> r2{{R2 ~ U(0,1)}}
    r2 --> z["Z = sqrt(-2 x ln(R1)) x cos(2 x pi x R2)"]
    z --> x["X = 5 + 0.333 x Z min"] --> rango{"3.333 <= X <= 6.667"}
    rango -->|no| r1
    rango -->|si| t["TConf = X"] --> fin((Fin))
