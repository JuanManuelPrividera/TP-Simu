a5 --> |no| c{"candidata == null"}
c --> |si| d["candidata = i_imp"] --> e["i_imp++"] --> a3
c --> |no| e
a4 --> |no| e
a3 --> |no| f{"candidata != null"}
f --> |si| g["i_imp = candidata"] --> h{{TConf}} --> fin
f --> |no| k["i_imp = null"] --> fin
