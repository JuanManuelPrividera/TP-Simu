%% Un lote del modelo equivale a 100 ejemplares físicos homogéneos.
%% Fuente: https://www.horizon.co.jp/products/catalog/e_pdf/e002bi/01bq1_pdf/BQ300_e.pdf
%% CantLotes sigue una normal discreta truncada: media 20, desvío 5 y
%% soporte [5, 35] lotes (tres desvíos respecto de la media).
flowchart TD
    inicio{{CantLotes}} --> z{{Z ~ N(20, 5)}} --> rango{"5 <= round(Z) <= 35"}
    rango -->|no| z
    rango -->|si| a["CantLotes = round(Z)"] --> fin((Fin))
