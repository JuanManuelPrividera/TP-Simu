flowchart TD
    CI[[C. I.]]
    CI --> I0["Leer CLI y configuracion"]
    I0 --> I1["Inicializar PRNG, EventQueue, metricas, CLM[0..3], CxM, SD[0..4], CLTA = 0"]
    I1 --> I2["Programar eventos iniciales"]
    I2 --> I3["TPLL = T + IA"]
    I3 --> I4["Para cada etapa i y maquina k programar TDF[i][k] = T + TEF[i]"]
    I4 --> DFM{"FMP > 0"}
    DFM -->|Si| I5["Para cada etapa i y maquina k programar TM[i][k] = T + FMP"]
    DFM -->|No| I6["Programar RHFM con eventos WINDOW_OPEN y WINDOW_CLOSE"]
    I5 --> I6
    I6 --> D0{"Hay eventos pendientes y pedidos completados < objetivo"}

    subgraph EVENTOS["Bucle evento a evento"]
        direction TB
        E0["Extraer proximo evento"]
        E1["Actualizar T = tiempo del evento"]
        E2{"Trace habilitado"}
        E3["Registrar evento en traza"]
        E4{"Tipo de evento"}
    end

    D0 -->|Si| E0
    D0 -->|No| O0
    E0 --> E1 --> E2
    E2 -->|Si| E3 --> E4
    E2 -->|No| E4

    subgraph LLEGADA["ORDER_ARRIVAL"]
        direction TB
        A0["Generar pedido con PCP, CUL, tipo de libro y prioridad"]
        A1["Calcular perfil de materiales del pedido"]
        A2["Dividir pedido en lotes de tamano CLPL"]
        A3["Encolar lotes en CLM[0]"]
        A4["Programar nueva llegada TPLL = T + IA"]
        A5["Intentar iniciar Impresion"]
        A6["Verificar reposicion de SD[0] y SD[1]"]
    end

    subgraph INICIO_ETAPA["STAGE_START"]
        direction TB
        S0{"Hay lote en CLM[i] y maquina disponible en CxM[i][k]"}
        S1{"SD materiales requeridos >= demanda del lote"}
        S2["Desencolar lote"]
        S3["Registrar espera en cola TPE[i]"]
        S4["Marcar maquina BUSY y lote IN_PROCESS"]
        S5["Programar fin de proceso segun etapa"]
        S6["TPI[k] o TPE[k] o TPQA o TPD"]
    end

    subgraph SETUP["SETUP_START / SETUP_END"]
        direction TB
        U0{"Cambio de tipo de libro respecto a ultimo lote"}
        U1["Marcar maquina SETUP"]
        U2["Registrar tiempo de setup"]
        U3["Programar fin de setup con TPM[i]"]
        U4["Al finalizar setup relanzar STAGE_START"]
    end

    subgraph FIN_ETAPA["STAGE_END"]
        direction TB
        F0["Registrar consumo energetico con CEM[i]"]
        F1["Consumir materiales del lote y actualizar SD[n]"]
        F2["Verificar si SD[n] <= SPR[n]"]
        F2A["Programar STOCK_REPLENISHMENT en T + TR[n]"]
        F3{"Etapa actual = QA"}
        F4{"Muestra de defecto < PD"}
        F5["Reencolar lote en CLM[0]"]
        F6["Intentar reiniciar Impresion"]
        F7{"Etapa actual = Embalaje"}
        F8["Marcar lote terminado y sumar CLTA"]
        F9{"CLTA >= CPTD"}
        F10["Programar Despacho"]
        F11["Mover lote a la siguiente CLM"]
        F12["Intentar iniciar siguiente etapa"]
        F13{"Mantenimiento pendiente en la maquina"}
        F14["Programar MAINTENANCE_DUE inmediato"]
        F15["Intentar nuevo lote en la misma etapa"]
    end

    subgraph FALLA["MACHINE_FAILURE / REPAIR_END"]
        direction TB
        R0{"Maquina inmune por estar en SETUP o MAINTENANCE"}
        R1["Marcar maquina FAILED"]
        R2{"Habia lote en proceso"}
        R3["Suspender lote y guardar tiempo restante"]
        R4["Programar reparacion con TDR[i]"]
        R5["Reprogramar proxima falla con TEF[i]"]
        R6["Registrar TSP[i]"]
        R7["Al reparar, marcar maquina IDLE"]
        R8{"Existe lote suspendido asociado"}
        R9["Reanudar lote y programar STAGE_END con tiempo restante"]
        R9A{"FMP > 0"}
        R10["Reprogramar mantenimiento preventivo desde T + FMP"]
        R11["Intentar iniciar lote pendiente"]
    end

    subgraph MANT["MAINTENANCE_DUE / MAINTENANCE_END"]
        direction TB
        M0{"Maquina FAILED"}
        M1{"Maquina BUSY"}
        M2["Marcar mantenimiento pendiente"]
        M3["Marcar maquina MAINTENANCE"]
        M4["Programar fin de mantenimiento con TMM[i]"]
        M5["Registrar TSP[i]"]
        M6["Al finalizar, marcar maquina IDLE"]
        M7{"FMP > 0"}
        M8["Programar nuevo mantenimiento preventivo"]
        M9["Reiniciar reloj de falla con TEF[i]"]
        M10["Intentar iniciar lote pendiente"]
    end

    subgraph REPOSICION["STOCK_REPLENISHMENT"]
        direction TB
        P0["Reponer material con TR[n]"]
        P1["Actualizar SD[n] y limpiar flag de reposicion"]
        P2["Intentar reiniciar etapas que usan ese material"]
    end

    subgraph DESPACHO["DISPATCH"]
        direction TB
        D1["Despachar todos los lotes almacenados"]
        D2["Vaciar almacenamiento y resetear CLTA"]
        D3["Agrupar lotes por pedido"]
        D4["Registrar TPPT por pedido completado"]
    end

    subgraph VENTANAS["WINDOW_OPEN / WINDOW_CLOSE"]
        direction TB
        W0["WINDOW_OPEN: intentar iniciar lotes en la etapa"]
        W1["WINDOW_CLOSE: no inicia nuevos lotes fuera de RHFM"]
    end

    E4 -->|ORDER_ARRIVAL| A0
    A0 --> A1 --> A2 --> A3 --> A4 --> A5 --> A6 --> DEND

    E4 -->|STAGE_START| S0
    S0 -->|Si| S1
    S0 -->|No| DEND
    S1 -->|Si| S2 --> S3 --> S4 --> S5 --> S6 --> DEND
    S1 -->|No| DEND

    E4 -->|SETUP_START| U0
    U0 -->|Si| U1 --> U2 --> U3 --> DEND
    U0 -->|No| DEND
    E4 -->|SETUP_END| U4 --> DEND

    E4 -->|STAGE_END| F0
    F0 --> F1 --> F2
    F2 -->|Si| F2A --> F3
    F2 -->|No| F3
    F3 -->|Si| F4
    F4 -->|Si| F5 --> F6 --> F13
    F4 -->|No| F11 --> F12 --> F13
    F3 -->|No| F7
    F7 -->|Si| F8 --> F9
    F9 -->|Si| F10 --> F13
    F9 -->|No| F13
    F7 -->|No| F11 --> F12 --> F13
    F13 -->|Si| F14 --> DEND
    F13 -->|No| F15 --> DEND

    E4 -->|MACHINE_FAILURE| R0
    R0 -->|Si| DEND
    R0 -->|No| R1 --> R2
    R2 -->|Si| R3 --> R4
    R2 -->|No| R4
    R4 --> R5 --> R6 --> DEND

    E4 -->|REPAIR_END| R7
    R7 --> R8
    R8 -->|Si| R9 --> DEND
    R8 -->|No| R9A
    R9A -->|Si| R10 --> R11 --> DEND
    R9A -->|No| R11 --> DEND

    E4 -->|MAINTENANCE_DUE| M0
    M0 -->|Si| DEND
    M0 -->|No| M1
    M1 -->|Si| M2 --> DEND
    M1 -->|No| M3 --> M4 --> M5 --> DEND

    E4 -->|MAINTENANCE_END| M6
    M6 --> M7
    M7 -->|Si| M8 --> M9 --> M10 --> DEND
    M7 -->|No| M9 --> M10 --> DEND

    E4 -->|STOCK_REPLENISHMENT| P0
    E4 -->|DISPATCH| D1
    D1 --> D2 --> D3 --> D4 --> DEND

    E4 -->|WINDOW_OPEN| W0 --> DEND
    E4 -->|WINDOW_CLOSE| W1 --> DEND

    DEND{"Continuar simulacion"}
    DEND -->|Si| D0
    DEND -->|No| O0[/"TPPT, TPPL, CxTP,\nTSP[i], TPE[i], PR"/]
    O0 --> FIN([ ])
